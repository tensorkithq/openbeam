{
  "name": "openbeam",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @openbeam/web dev",
    "dev:server": "cd apps/server && cargo run",
    "build": "pnpm --filter @openbeam/web build",
    "build:server": "cd apps/server && cargo build --release",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @openbeam/web test:e2e"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "version": "0.1.0"
}
